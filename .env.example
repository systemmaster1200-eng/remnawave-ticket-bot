# Токен Telegram бота (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# URL API Remnawave (без слеша в конце)
REMNAWAVE_API_URL=https://api.remnawave.example.com

# Токен авторизации для API Remnawave
REMNAWAVE_API_TOKEN=your_api_token_here

# Bedolaga (веб-API бота): баланс и кнопка «Транзакции» в карточке. Необязательно.
# BEDOLAGA_API_URL=https://mybot.example.com
# BEDOLAGA_API_TOKEN=your_web_api_token

# Groq AI: автоответы поддержки. Поддерживаются GROQ_API_KEY или AI_SUPPORT_API_KEY (как в STELS-Support).
# Несколько ключей (fallback): AI_SUPPORT_API_KEYS=gsk_1,gsk_2
# GROQ_MODELS — только модели, доступные в вашем проекте (при 403 проверьте Model Permissions в консоли Groq).
# Рабочий список моделей (2025): llama-3.1-8b-instant, qwen/qwen3-32b, llama-3.3-70b-versatile, meta-llama/llama-4-scout-17b-16e-instruct, moonshotai/kimi-k2-instruct, openai/gpt-oss-120b, openai/gpt-oss-20b, groq/compound-mini, groq/compound и др.
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.1-8b-instant
# GROQ_MODELS=llama-3.1-8b-instant,qwen/qwen3-32b,llama-3.3-70b-versatile,meta-llama/llama-4-scout-17b-16e-instruct,moonshotai/kimi-k2-instruct,openai/gpt-oss-120b,openai/gpt-oss-20b
# Прокси для Groq (если с этого сервера 403 — задай HTTP-прокси с «белого» IP): http://host:port или http://user:pass@host:port
# GROQ_PROXY=http://127.0.0.1:8080

# Список ID менеджеров, которым разрешен доступ к боту (через запятую)
ALLOWED_MANAGER_IDS=123456789,987654321

# Название сервиса (отображается клиентам: «Это поддержка {SERVICE_NAME}», в карточке «Данные из API {SERVICE_NAME}»)
SERVICE_NAME=Remnawave

# Домен мини-приложения для менеджеров
MINI_APP_DOMAIN=mini.stealthnet.app

# Email для Let's Encrypt (SSL-сертификаты). Обязательно для первого запуска nginx
CERTBOT_EMAIL=your@email.com

# ID группы поддержки (forum с топиками). Каждый тикет — новый топик (Важно дать боту права админа и разрешение создавать топик).
SUPPORT_GROUP_ID=-1001235327890

# Freekassa (Kassa.ai) — платёжная система «Выставить счёт»
# API ключ кассы и ID магазина — в ЛК (раздел «Мои кассы»). Секрет 2 — для вебхука. Секрет 1 — только если при 401 попросили подпись от него.
# FREEEKASSA_API_KEY=
# FREEEKASSA_SHOP_ID=
# FREEEKASSA_WEBHOOK_SECRET=
# По умолчанию подпись от API ключа (как в BEDOLAGA). Секрет 1 — только если касса требует:
# FREEEKASSA_SECRET1=
# FREEEKASSA_USE_SECRET1_FOR_SIGN=1
# PAYMENTS_BASE_URL=https://your-domain.com
# SERVER_PUBLIC_IP=   # публичный IP сервера для Freekassa (если не задан — запрашивается при первом счёте)
# PAYMENTS_DATA_DIR=/data

# Файл сохранения состояния бота (топики поддержки, счётчик тикетов, user_data). После перезапуска данные восстанавливаются.
PERSISTENCE_PATH=/data/bot_state.pickle

